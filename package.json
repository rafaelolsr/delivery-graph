{
  "name": "delivery-graph-engineering",
  "version": "0.2.1",
  "description": "Turn demands into validated delivery graphs across agent harnesses and task trackers.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaelolsr/delivery-graph.git"
  },
  "homepage": "https://github.com/rafaelolsr/delivery-graph#readme",
  "bugs": {
    "url": "https://github.com/rafaelolsr/delivery-graph/issues"
  },
  "bin": {
    "dge": "./bin/dge.mjs"
  },
  "files": [
    "adapters/",
    "assets/",
    "bin/",
    "docs/",
    "examples/",
    "manifests/",
    "schemas/",
    "scripts/",
    "skills/",
    "src/",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "validate": "node scripts/validate-graph.mjs examples/delivery-graph.example.json",
    "status": "node scripts/render-status.mjs examples/delivery-graph.example.json",
    "transition": "node scripts/transition-node.mjs",
    "dge": "node bin/dge.mjs",
    "test": "node --test",
    "check": "npm run validate && npm run status && npm test"
  },
  "keywords": [
    "agentic-workflow",
    "delivery-graph",
    "linear",
    "azure-devops",
    "multi-harness",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
